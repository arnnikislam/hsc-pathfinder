rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — anyone logged in can read profiles (for leaderboard avatars/names)
    // Only the user themselves can write their own doc
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Study logs — anyone logged in can read all logs (needed to build leaderboard)
    // Users can only create/edit/delete their own logs
    match /studyLogs/{logId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update,
            delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
  }
}

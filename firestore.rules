rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin UID
    function isAdmin() {
      return request.auth != null &&
             request.auth.uid == '9vzlZq07o4MCRMm50zdTnYwFSLI2';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // USERS collection
    match /users/{userId} {
      // Anyone logged in can read (leaderboard needs this)
      allow read: if isLoggedIn();
      // User can write their own doc, admin can write any
      allow write: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
    }

    // STUDY LOGS
    match /studyLogs/{logId} {
      // Anyone logged in can read (leaderboard + graph)
      allow read: if isLoggedIn();
      // User can create their own logs
      allow create: if isLoggedIn() &&
                    request.resource.data.userId == request.auth.uid;
      // User can update/delete own logs, admin can delete any
      allow update, delete: if isLoggedIn() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ANNOUNCEMENTS — admin writes, everyone reads
    match /announcements/{annoId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }
  }
}
